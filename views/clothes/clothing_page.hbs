<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <h1>👕 Магазин одягу</h1>
    <a href="/clothing/create" style="background: #16a34a; color: white; padding: 10px 20px; text-decoration: none; border-radius: 8px; font-weight: bold;">➕ Додати товар</a>
</div>

<table>
    <thead>
        <tr>
            <th>Тип</th>
            <th>Бренд</th>
            <th>Розмір</th>
            <th>Ціна</th>
            <th>На складі</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        {{#each items}}
        <tr>
            <td><strong>{{this.type}}</strong></td>
            <td>{{this.brand}}</td>
            <td>{{this.size}}</td>
            <td style="color: #16a34a; font-weight: bold;">${{this.price}}</td>
            <td>{{this.stock_quantity}} шт.</td> <td>
                <form action="/clothing/delete/{{this.id}}" method="POST" onsubmit="return confirm('Видалити цей товар?')">
                    <button type="submit" style="color: #dc2626; background: none; border: none; cursor: pointer; text-decoration: underline;">Видалити</button>
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

<div style="margin-top: 30px;">
    <a href="/" style="color: #64748b; text-decoration: none;">🏠 На головну</a>
</div>